# Copy this to .env and fill in your values
# On Railway, set these as environment variables in the dashboard

# Flask secret key - generate a random string, keep it secret
SECRET_KEY=your-very-long-random-secret-key-here

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=generated-during-setup
ADMIN_EMAIL=qbixcentre@outlook.com
ADMIN_PHONE=4787379107

# Twilio SMS (used for 2FA login codes)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+14785551234

# Anthropic API for newsletter generation
ANTHROPIC_API_KEY=your-anthropic-api-key

# Cloudinary (photo storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Google Analytics
GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA_API_SECRET=your-ga-api-secret

# App settings
APP_URL=https://qbixcentre.com
DATA_FILE=qbix_data.json
